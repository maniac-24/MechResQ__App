  "needHelpDescription": "ವಾಹನ ಬ್ರೇಕ್‌ಡೌನ್ ಸಮಯದಲ್ಲಿ ನಿಮಗೆ ಸಹಾಯ ಮಾಡಲು ನಾವು 24/7 ಇಲ್ಲಿದ್ದೇವೆ",
  "frequentlyAskedQuestions": "ಪದೇ ಪದೇ ಕೇಳಲಾಗುವ ಪ್ರಶ್ನೆಗಳು",
  "faqUnableToLogin": "ನಾನು ಆ್ಯಪ್‌ಗೆ ಲಾಗಿನ್ ಆಗಲು ಸಾಧ್ಯವಾಗುತ್ತಿಲ್ಲ",
  "faqUnableToLoginAnswer": "ಲಾಗಿನ್ ಸಮಸ್ಯೆಗಳು ಸಾಮಾನ್ಯವಾಗಿ ಕಳಪೆ ನೆಟ್‌ವರ್ಕ್ ಸಂಪರ್ಕದಿಂದಾಗಿ ಉಂಟಾಗುತ್ತದೆ. ದಯವಿಟ್ಟು ನಿಮ್ಮ ಇಂಟರ್ನೆಟ್ ಸಂಪರ್ಕ ಮತ್ತು ನಿಮ್ಮ ನೆಟ್‌ವರ್ಕ್ ಪೂರೈಕೆದಾರರ ಸಿಗ್ನಲ್ ಶಕ್ತಿಯನ್ನು ಪರಿಶೀಲಿಸಿ. ನೀವು Play Store ನಿಂದ ಆ್ಯಪ್ ಅನ್ನು ಮರುಸ್ಥಾಪಿಸಲು ಪ್ರಯತ್ನಿಸಬಹುದು.\n\nನೀವು OTP ವಿವರಗಳೊಂದಿಗೆ SMS ಸ್ವೀಕರಿಸದಿದ್ದರೆ, ನಮೂದಿಸಿದ ಮೊಬೈಲ್ ಸಂಖ್ಯೆ ಮಾನ್ಯವಾಗಿದೆಯೇ ಎಂದು ಪರಿಶೀಲಿಸಿ.\n\nನಮೂದಿಸಿದ ಮೊಬೈಲ್ ಸಂಖ್ಯೆ ಸರಿಯಾಗಿದ್ದರೂ OTP ವಿವರಗಳೊಂದಿಗೆ SMS ಸ್ವೀಕರಿಸದಿದ್ದರೆ, ನೆಟ್‌ವರ್ಕ್ ಸಮಸ್ಯೆಗಳಿಂದಾಗಿ SMS ಸ್ವೀಕರಿಸುವಲ್ಲಿ ವಿಳಂಬವಾಗಬಹುದು ಎಂದು ನಾವು ಕೆಲವು ನಿಮಿಷಗಳು ಕಾಯಲು ವಿನಂತಿಸುತ್ತೇವೆ.\n\nಆದರೆ, ನೀವು ಇನ್ನೂ ಯಾವುದೇ ಸಮಸ್ಯೆಯನ್ನು ಎದುರಿಸುತ್ತಿದ್ದರೆ, ದಯವಿಟ್ಟು ನಮ್ಮ ಬೆಂಬಲ ತಂಡವನ್ನು ಸಂಪರ್ಕಿಸಿ.",
  "faqNotReceivingOtp": "OTP ಸ್ವೀಕರಿಸುತ್ತಿಲ್ಲ",
  "faqNotReceivingOtpAnswer": "• ನಿಮ್ಮ ಮೊಬೈಲ್ ನೆಟ್‌ವರ್ಕ್ ಸಿಗ್ನಲ್ ಶಕ್ತಿ ಪರಿಶೀಲಿಸಿ\n• ನಮೂದಿಸಿದ ಮೊಬೈಲ್ ಸಂಖ್ಯೆ ಸರಿಯಾಗಿದೆಯೇ ಎಂದು ಪರಿಶೀಲಿಸಿ\n• OTP ಸಂದೇಶಗಳು ಬರಲು 2-3 ನಿಮಿಷಗಳವರೆಗೆ ಸಮಯ ತೆಗೆದುಕೊಳ್ಳಬಹುದು\n• ನಿಮ್ಮ ಸಾಧನದಲ್ಲಿ SMS ಸಂಗ್ರಹಣೆ ಪೂರ್ಣವಾಗಿದೆಯೇ ಎಂದು ಪರಿಶೀಲಿಸಿ\n• ನಿಮ್ಮ ಫೋನ್ ಮರುಪ್ರಾರಂಭಿಸಿ ಮತ್ತು OTP ಪುನಃ ವಿನಂತಿಸಿ\n• ನೀವು ಅಪರಿಚಿತ ಸಂಖ್ಯೆಗಳಿಂದ SMS ನಿರ್ಬಂಧಿಸಿಲ್ಲವೇ ಎಂದು ಖಚಿತಪಡಿಸಿಕೊಳ್ಳಿ\n\n5 ನಿಮಿಷಗಳ ನಂತರವೂ ಸಮಸ್ಯೆ ಮುಂದುವರಿದರೆ, \"Resend OTP\" ಟ್ಯಾಪ್ ಮಾಡಿ ಅಥವಾ ಬೆಂಬಲವನ್ನು ಸಂಪರ್ಕಿಸಿ.",
  "faqInvalidOtp": "ಅಮಾನ್ಯ OTP ದೋಷ",
  "faqInvalidOtpAnswer": "ಈ ದೋಷವು ಸಂಭವಿಸುತ್ತದೆ:\n\n• ನೀವು ತಪ್ಪು OTP ಕೋಡ್ ನಮೂದಿಸಿದ್ದೀರಿ\n• OTP ಅವಧಿ ಮೀರಿದೆ (ಕೇವಲ 10 ನಿಮಿಷಗಳವರೆಗೆ ಮಾನ್ಯವಾಗಿದೆ)\n• ನೆಟ್‌ವರ್ಕ್ ವಿಳಂಬದಿಂದ ಪರಿಶೀಲನೆ ಸಮಯ ಮೀರಿದೆ\n\nಪರಿಹಾರಗಳು:\n1. SMS ನಿಂದ 6-ಅಂಕಿಯ ಕೋಡ್ ಎರಡು ಬಾರಿ ಪರಿಶೀಲಿಸಿ\n2. 10 ನಿಮಿಷಗಳಿಗಿಂತ ಹೆಚ್ಚು ಸಮಯ ಕಳೆದಿದ್ದರೆ ಹೊಸ OTP ವಿನಂತಿಸಿ\n3. ಪರಿಶೀಲನೆ ಸಮಯದಲ್ಲಿ ಸ್ಥಿರ ಇಂಟರ್ನೆಟ್ ಸಂಪರ್ಕ ಖಚಿತಪಡಿಸಿಕೊಳ್ಳಿ\n4. ಟೈಪ್ ಮಾಡುವ ಬದಲು OTP ಅನ್ನು ನಕಲಿಸಿ ಮತ್ತು ಅಂಟಿಸಲು ಪ್ರಯತ್ನಿಸಿ",
  "faqAppCrashes": "ಲಾಗಿನ್ ಸಮಯದಲ್ಲಿ ಆ್ಯಪ್ ಕ್ರ್ಯಾಶ್ ಆಗುತ್ತದೆ",
  "faqAppCrashesAnswer": "ಲಾಗಿನ್ ಸಮಯದಲ್ಲಿ ಆ್ಯಪ್ ಕ್ರ್ಯಾಶ್ ಅಥವಾ ಫ್ರೀಜ್ ಆದರೆ:\n\n1. ಆ್ಯಪ್ ಸಂಪೂರ್ಣವಾಗಿ ಬಲವಂತವಾಗಿ ಮುಚ್ಚಿ\n2. ಆ್ಯಪ್ ಕ್ಯಾಶ್ ತೆರವುಗೊಳಿಸಿ: ಸೆಟ್ಟಿಂಗ್ಸ್ → ಆ್ಯಪ್ಸ್ → MechResQ → Clear Cache\n3. Play Store ನಲ್ಲಿ ಆ್ಯಪ್ ನವೀಕರಣಗಳಿಗಾಗಿ ಪರಿಶೀಲಿಸಿ\n4. ಸ್ಥಿರ ಇಂಟರ್ನೆಟ್ ಇದೆಯೇ ಎಂದು ಖಚಿತಪಡಿಸಿಕೊಳ್ಳಿ (WiFi ಶಿಫಾರಸು)\n5. ಫೋನ್ ಸಂಗ್ರಹಣೆ ಮುಕ್ತಗೊಳಿಸಿ (ಕನಿಷ್ಠ 100MB ಮುಕ್ತ ಸ್ಥಳ)\n6. ನಿಮ್ಮ ಸಾಧನ ಮರುಪ್ರಾರಂಭಿಸಿ\n\nಸಮಸ್ಯೆ ಮುಂದುವರಿದರೆ, ಆ್ಯಪ್ ಅನ್ನು ಅಸ್ಥಾಪಿಸಿ ಮತ್ತು ಮರುಸ್ಥಾಪಿಸಿ. ನಿಮ್ಮ ಡೇಟಾ ಸುರಕ್ಷಿತವಾಗಿದೆ ಮತ್ತು ಲಾಗಿನ್ ಆದ ನಂತರ ಮರುಸ್ಥಾಪಿಸಲಾಗುತ್ತದೆ.",
  "faqChangedPhoneNumber": "ನನ್ನ ಫೋನ್ ಸಂಖ್ಯೆಯನ್ನು ಬದಲಾಯಿಸಿದ್ದೇನೆ",
  "faqChangedPhoneNumberAnswer": "ನೀವು ನಿಮ್ಮ ಮೊಬೈಲ್ ಸಂಖ್ಯೆಯನ್ನು ಬದಲಾಯಿಸಿದ್ದರೆ:\n\n1. ನಿಮ್ಮ ಹೊಸ ಫೋನ್ ಸಂಖ್ಯೆಯೊಂದಿಗೆ ಲಾಗಿನ್ ಮಾಡಿ\n2. OTP ಪರಿಶೀಲನೆ ಪೂರ್ಣಗೊಳಿಸಿ\n3. ನಿಮ್ಮ ಖಾತೆ ಹೊಸ ಸಂಖ್ಯೆಯೊಂದಿಗೆ ರಚಿಸಲಾಗುತ್ತದೆ\n4. ನಂತರ ನಿಮ್ಮ ಪ್ರೊಫೈಲ್ ಮತ್ತೆ ಸೆಟ್ಅಪ್ ಮಾಡಬಹುದು\n\nಗಮನಿಸಿ: ಹಿಂದಿನ ಸೇವಾ ಇತಿಹಾಸವನ್ನು ಹೊಸ ಸಂಖ್ಯೆಗೆ ವರ್ಗಾಯಿಸಲು ಸಾಧ್ಯವಿಲ್ಲ. ನಿಮ್ಮ ಹಳೆಯ ಖಾತೆ ಡೇಟಾವನ್ನು ಲಿಂಕ್ ಮಾಡಲು ಬೇಕಾದರೆ ಬೆಂಬಲವನ್ನು ಸಂಪರ್ಕಿಸಿ.",
