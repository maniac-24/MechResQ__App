  "frequentlyAskedQuestions": "ಪದೇ ಪದೇ ಕೇಳಲಾಗುವ ಪ್ರಶ್ನೆಗಳು",
  "viewAll": "ಎಲ್ಲವನ್ನೂ ವೀಕ್ಷಿಸಿ",
  "faqQuestion1": "ನಾನು ಮೆಕ್ಯಾನಿಕ್ ಅನ್ನು ಹೇಗೆ ವಿನಂತಿಸಬಹುದು?",
  "faqAnswer1": "1. ಮುಖಪುಟಕ್ಕೆ ಹೋಗಿ\n2. ಹತ್ತಿರದ ಮೆಕ್ಯಾನಿಕ್‌ಗಳನ್ನು ಬ್ರೌಸ್ ಮಾಡಿ ಅಥವಾ ಫಿಲ್ಟರ್‌ಗಳ ಮೂಲಕ ಹುಡುಕಿ\n3. ಮೆಕ್ಯಾನಿಕ್ ಆಯ್ಕೆಮಾಡಿ\n4. 'ಸೇವೆಯನ್ನು ವಿನಂತಿಸಿ' ಟ್ಯಾಪ್ ಮಾಡಿ\n5. ನಿಮ್ಮ ವಾಹನ ವಿವರಗಳು ಮತ್ತು ಸಮಸ್ಯೆಯನ್ನು ಭರ್ತಿ ಮಾಡಿ\n6. ನಿಮ್ಮ ಸ್ಥಳವನ್ನು ದೃಢೀಕರಿಸಿ\n7. ವಿನಂತಿಯನ್ನು ಸಲ್ಲಿಸಿ",
  "faqQuestion2": "ದೂರವನ್ನು ಹೇಗೆ ಲೆಕ್ಕ ಹಾಕಲಾಗುತ್ತದೆ?",
  "faqAnswer2": "ನಿಮ್ಮ ಪ್ರಸ್ತುತ ಸ್ಥಳ ಮತ್ತು ಮೆಕ್ಯಾನಿಕ್‌ನ ವರ್ಕ್‌ಶಾಪ್ ನಡುವಿನ GPS ನಿರ್ದೇಶಾಂಕಗಳನ್ನು ಬಳಸಿ ದೂರವನ್ನು ಲೆಕ್ಕ ಹಾಕಲಾಗುತ್ತದೆ. ನಿಖರವಾದ ಫಲಿತಾಂಶಗಳಿಗಾಗಿ ಸ್ಥಳ ಸೇವೆಗಳನ್ನು ಸಕ್ರಿಯಗೊಳಿಸಿರುವುದನ್ನು ಖಚಿತಪಡಿಸಿಕೊಳ್ಳಿ.",
  "faqQuestion3": "ನಾನು ಅನೇಕ ವಾಹನಗಳನ್ನು ಸೇರಿಸಬಹುದೇ?",
  "faqAnswer3": "ಹೌದು! ನಿಮ್ಮ ಪ್ರೊಫೈಲ್ ಐಕಾನ್ ಟ್ಯಾಪ್ ಮಾಡುವ ಮೂಲಕ ಮೆನು ತೆರೆಯಿರಿ, 'ನನ್ನ ವಾಹನಗಳು' ಆಯ್ಕೆಮಾಡಿ ಮತ್ತು ಅನಿಯಮಿತ ವಾಹನಗಳನ್ನು ಸೇರಿಸಿ. ಸೇವಾ ವಿನಂತಿಗಳನ್ನು ರಚಿಸುವಾಗ ನೀವು ಅವುಗಳ ನಡುವೆ ಬದಲಾಯಿಸಬಹುದು.",
  "faqQuestion4": "ತುರ್ತು ಪರಿಸ್ಥಿತಿಯಲ್ಲಿ ನಾನು ಏನು ಮಾಡಬೇಕು?",
  "faqAnswer4": "1. SOS ಬಟನ್ ಟ್ಯಾಪ್ ಮಾಡಿ (ಮೆನುದಲ್ಲಿ ಕೆಂಪು ಬಟನ್)\n2. ನಿಮ್ಮ ಸ್ಥಳವನ್ನು ಸ್ವಯಂಚಾಲಿತವಾಗಿ ಹಂಚಿಕೊಳ್ಳಲಾಗುತ್ತದೆ\n3. ತುರ್ತು ಸಂಪರ್ಕಗಳಿಗೆ ತಿಳಿಸಲಾಗುತ್ತದೆ\n4. ಹತ್ತಿರದ ಮೆಕ್ಯಾನಿಕ್‌ಗಳಿಗೆ ಎಚ್ಚರಿಕೆ ನೀಡಲಾಗುತ್ತದೆ\n5. ನಿಮ್ಮ ವಾಹನದಲ್ಲಿ ಶಾಂತವಾಗಿ ಮತ್ತು ಸುರಕ್ಷಿತವಾಗಿರಿ",
  "faqQuestion5": "ಪಾವತಿಗಳು ಹೇಗೆ ಕೆಲಸ ಮಾಡುತ್ತವೆ?",
  "faqAnswer5": "ಎಲ್ಲಾ ಪಾವತಿಗಳನ್ನು ಆ್ಯಪ್ ಮೂಲಕ ಸುರಕ್ಷಿತವಾಗಿ ಪ್ರಕ್ರಿಯೆಗೊಳಿಸಲಾಗುತ್ತದೆ. ಸೇವೆ ಪೂರ್ಣಗೊಂಡ ನಂತರ ನೀವು UPI, ಕಾರ್ಡ್‌ಗಳು ಅಥವಾ ವಾಲೆಟ್‌ಗಳ ಮೂಲಕ ಪಾವತಿಸಬಹುದು. ನಗದು ಪಾವತಿಗಳನ್ನು ಮೆಕ್ಯಾನಿಕ್‌ನ ವಿವೇಚನೆಯಿಂದ ಸ್ವೀಕರಿಸಲಾಗುತ್ತದೆ.",
  "faqQuestion6": "ನಾನು ವಿನಂತಿಯನ್ನು ರದ್ದುಗೊಳಿಸಬಹುದೇ?",
  "faqAnswer6": "ಹೌದು, ಮೆಕ್ಯಾನಿಕ್ ಅದನ್ನು ಸ್ವೀಕರಿಸುವ ಮೊದಲು ನೀವು ರದ್ದುಗೊಳಿಸಬಹುದು. ನನ್ನ ವಿನಂತಿಗಳು → ವಿನಂತಿ ಆಯ್ಕೆಮಾಡಿ → 'ರದ್ದುಮಾಡು' ಟ್ಯಾಪ್ ಮಾಡಿ. ಮೆಕ್ಯಾನಿಕ್ ಈಗಾಗಲೇ ಪ್ರಯಾಣ ಪ್ರಾರಂಭಿಸಿದ್ದರೆ ರದ್ದತಿ ಶುಲ್ಕಗಳು ಅನ್ವಯವಾಗಬಹುದು.",
  "emergencySafety": "ತುರ್ತು ಮತ್ತು ಸುರಕ್ಷತೆ",
  "safetyGuidelines": "ಸುರಕ್ಷತಾ ಮಾರ್ಗಸೂಚಿಗಳು",
  "safetyTips": "• ಅಸುರಕ್ಷಿತ ಸ್ಥಳದಲ್ಲಿ ಸಿಲುಕಿದರೆ, ಬಾಗಿಲುಗಳು ಲಾಕ್ ಮಾಡಿ ನಿಮ್ಮ ವಾಹನದಲ್ಲಿಯೇ ಇರಿ\n• ಹ್ಯಾಜರ್ಡ್ ಲೈಟ್‌ಗಳನ್ನು ಆನ್ ಮಾಡಿ ಮತ್ತು ಲಭ್ಯವಿದ್ದರೆ ಎಚ್ಚರಿಕೆ ತ್ರಿಕೋನಗಳನ್ನು ಬಳಸಿ\n• ತಕ್ಷಣದ ತುರ್ತು ಸಹಾಯಕ್ಕಾಗಿ SOS ಕರೆ ವೈಶಿಷ್ಟ್ಯವನ್ನು ಬಳಸಿ\n• ಯಾರೊಂದಿಗೂ OTP, ಪಾಸ್‌ವರ್ಡ್‌ಗಳು ಅಥವಾ ಬ್ಯಾಂಕಿಂಗ್ ವಿವರಗಳನ್ನು ಹಂಚಿಕೊಳ್ಳಬೇಡಿ\n• ಸೇವೆಯನ್ನು ಸ್ವೀಕರಿಸುವ ಮೊದಲು ಮೆಕ್ಯಾನಿಕ್ ID ಮತ್ತು ರೇಟಿಂಗ್ ಪರಿಶೀಲಿಸಿ\n• ಎಲ್ಲಾ ಪಾವತಿಗಳನ್ನು ಆ್ಯಪ್ ಮೂಲಕ ಮಾತ್ರ ಮಾಡಬೇಕು\n• ದುರಸ್ತಿ ಮಾಡುವ ಮೊದಲು ಮತ್ತು ನಂತರ ಹಾನಿಯ ಫೋಟೋಗಳನ್ನು ತೆಗೆಯಿರಿ\n• ತುರ್ತು ಸಂಖ್ಯೆಗಳನ್ನು ನಿಮ್ಮ ಫೋನ್‌ನಲ್ಲಿ ಉಳಿಸಿ",
